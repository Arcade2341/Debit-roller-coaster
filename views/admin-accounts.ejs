<%- include("partials/head", { pageTitle }) %>
<%- include("partials/header") %>

<main class="dashboard-page">
  <section class="container">
    <div class="dashboard-grid">
      <section class="dashboard-card">
        <div class="section-head">
          <h1>Comptes</h1>
        </div>

        <%- include("partials/flash") %>

        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Pseudo</th>
                <th>Statut</th>
                <th>Helper</th>
                <th>Calculs</th>
                <th>Date de creation</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach((account) => { %>
                <tr>
                  <td><%= account.username %></td>
                  <td><%= account.is_admin ? "Admin" : "Utilisateur" %></td>
                  <td><%= account.is_helper ? "Oui" : "Non" %></td>
                  <td><%= account.calculations_count %></td>
                  <td><%= account.created_at.slice(0, 10) %></td>
                  <td>
                    <div class="table-actions">
                      <form action="/admin/users/<%= account.id %>/toggle-admin" method="post">
                        <button type="submit" class="history-delete-button">
                          <%= account.is_admin ? "Retirer admin" : "Passer admin" %>
                        </button>
                      </form>
                      <form action="/admin/users/<%= account.id %>/toggle-helper" method="post">
                        <button type="submit" class="history-delete-button">
                          <%= account.is_helper ? "Retirer helper" : "Passer helper" %>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <aside class="dashboard-card">
        <div class="section-head">
          <h2>Roles</h2>
        </div>

        <p class="empty-state">
          Le role helper sert uniquement a traiter les demandes d'ajout.
        </p>

        <p class="empty-state">
          Les admins gardent la gestion des comptes et peuvent nommer les helpers.
        </p>
      </aside>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
