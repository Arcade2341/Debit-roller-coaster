<%- include("partials/head", { pageTitle, metaRobots: "noindex,nofollow" }) %>
<%- include("partials/header") %>

<main class="auth-page">
  <section class="container form-page">
    <div class="form-shell">
      <div class="section-head">
        <h1><%= t("requests.requestRide") %></h1>
      </div>

      <%- include("partials/flash") %>

      <form action="/attraction-requests" method="post" class="stack-form">
        <label class="field">
          <span><%= t("requests.ride") %></span>
          <input type="text" name="attractionName" minlength="3" maxlength="80" required />
        </label>

        <label class="field">
          <span><%= t("requests.park") %></span>
          <input type="text" name="parkName" minlength="2" maxlength="80" required />
        </label>

        <label class="field">
          <span><%= t("requests.country") %></span>
          <input type="text" name="countryName" minlength="2" maxlength="60" required />
        </label>

        <label class="field">
          <span><%= t("requests.peopleTrain") %></span>
          <input type="number" name="peoplePerTrain" min="1" max="100" required />
        </label>

        <button type="submit" class="primary-button"><%= t("requests.sendRequest") %></button>
      </form>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
