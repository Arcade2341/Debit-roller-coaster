<%- include("partials/head", { pageTitle, metaRobots: "noindex,nofollow" }) %>
<%- include("partials/header") %>

<main class="dashboard-page">
  <section class="container">
    <div class="page-intro">
      <div class="section-head">
        <h1><%= t("dashboard.title") %></h1>
        <p><%= t("dashboard.intro") %></p>
      </div>
    </div>

    <div class="dashboard-grid">
      <section class="dashboard-card">
        <div class="section-head">
          <h2><%= t("dashboard.calculations") %></h2>
        </div>

        <%- include("partials/flash") %>

        <% if (calculations.length === 0) { %>
          <p class="empty-state"><%= t("dashboard.noCalculations") %></p>
        <% } else { %>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th><%= t("dashboard.ride") %></th>
                  <th><%= t("dashboard.peopleTrain") %></th>
                  <th><%= t("dashboard.trainsPeriod") %></th>
                  <th><%= t("dashboard.throughputHour") %></th>
                  <th><%= t("dashboard.date") %></th>
                  <th><%= t("dashboard.time") %></th>
                  <th><%= t("dashboard.action") %></th>
                </tr>
              </thead>
              <tbody>
                <% calculations.forEach((entry) => { %>
                  <tr>
                    <td><%= entry.attraction_name %></td>
                    <td><%= entry.people_per_train %></td>
                    <td><%= `${entry.trains_in_two_minutes} / ${entry.train_window_minutes || 2} min` %></td>
                    <td><%= entry.throughput_per_hour %></td>
                    <td><%= entry.recorded_date %></td>
                    <td><%= entry.recorded_time %></td>
                    <td>
                      <form action="/calculations/<%= entry.id %>/delete" method="post">
                        <button type="submit" class="history-delete-button"><%= t("dashboard.delete") %></button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <div class="account-actions">
          <div class="account-actions-head">
            <span class="account-actions-label"><%= t("dashboard.account") %></span>
            <strong><%= t("dashboard.sensitiveActions") %></strong>
          </div>

          <form action="/logout" method="post">
            <button type="submit" class="account-action-button account-action-logout"><%= t("dashboard.logout") %></button>
          </form>

          <form action="/account/delete" method="post">
            <button type="submit" class="account-action-button account-action-delete"><%= t("dashboard.deleteAccount") %></button>
          </form>
        </div>
      </section>

      <aside class="dashboard-card">
        <div class="section-head">
          <h2><%= t("dashboard.notifications") %></h2>
        </div>

        <% if (notifications.length === 0) { %>
          <p class="empty-state"><%= t("dashboard.noNotifications") %></p>
        <% } else { %>
          <div class="notifications-list compact">
            <% notifications.forEach((notification) => { %>
              <article class="notification-item <%= notification.is_read ? 'is-read' : 'is-unread' %>">
                <div class="notification-meta">
                  <span><%= resolveNotificationTargetLabel(notification.target_role) %></span>
                  <span><%= notification.created_at.slice(0, 10) %></span>
                </div>
                <h3><%= notification.title %></h3>
                <p><%= notification.message %></p>
              </article>
            <% }) %>
          </div>

          <a href="/notifications" class="ghost-button button-link"><%= t("dashboard.viewAllNotifications") %></a>
        <% } %>

        <div class="section-head compact">
          <h2><%= t("dashboard.updateUsername") %></h2>
        </div>

        <form action="/account/username" method="post" class="stack-form">
          <label class="field">
            <span><%= t("dashboard.newUsername") %></span>
            <input type="text" name="username" value="<%= user.username %>" minlength="3" maxlength="30" required />
          </label>

          <button type="submit" class="ghost-button"><%= t("dashboard.updateUsernameButton") %></button>
        </form>

        <div class="section-head compact">
          <h2><%= t("dashboard.changePassword") %></h2>
        </div>

        <form action="/account/password" method="post" class="stack-form">
          <label class="field">
            <span><%= t("auth.currentPassword") %></span>
            <input type="password" name="currentPassword" required />
          </label>

          <label class="field">
            <span><%= t("auth.newPassword") %></span>
            <input type="password" name="newPassword" minlength="8" required />
          </label>

          <label class="field">
            <span><%= t("auth.confirmation") %></span>
            <input type="password" name="confirmNewPassword" minlength="8" required />
          </label>

          <button type="submit" class="primary-button"><%= t("dashboard.updateButton") %></button>
        </form>
      </aside>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
