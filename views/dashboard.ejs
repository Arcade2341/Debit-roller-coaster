<%- include("partials/head", { pageTitle, metaRobots: "noindex,nofollow" }) %>
<%- include("partials/header") %>

<main class="dashboard-page">
  <section class="container">
    <div class="page-intro">
      <div class="section-head">
        <h1>Mon espace</h1>
        <p>Historique, notifications et reglages du compte.</p>
      </div>
    </div>

    <div class="dashboard-grid">
      <section class="dashboard-card">
        <div class="section-head">
          <h2>Vos calculs</h2>
        </div>

        <%- include("partials/flash") %>

        <% if (calculations.length === 0) { %>
          <p class="empty-state">Aucun calcul enregistre pour le moment.</p>
        <% } else { %>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Attraction</th>
                  <th>Personnes/train</th>
                  <th>Trains/2 min</th>
                  <th>Debit/heure</th>
                  <th>Date</th>
                  <th>Heure</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% calculations.forEach((entry) => { %>
                  <tr>
                    <td><%= entry.attraction_name %></td>
                    <td><%= entry.people_per_train %></td>
                    <td><%= entry.trains_in_two_minutes %></td>
                    <td><%= entry.throughput_per_hour %></td>
                    <td><%= entry.recorded_date %></td>
                    <td><%= entry.recorded_time %></td>
                    <td>
                      <form action="/calculations/<%= entry.id %>/delete" method="post">
                        <button type="submit" class="history-delete-button">Supprimer</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <div class="account-actions">
          <div class="account-actions-head">
            <span class="account-actions-label">Compte</span>
            <strong>Actions sensibles</strong>
          </div>

          <form action="/logout" method="post">
            <button type="submit" class="account-action-button account-action-logout">Deconnexion</button>
          </form>

          <form action="/account/delete" method="post">
            <button type="submit" class="account-action-button account-action-delete">Supprimer le compte</button>
          </form>
        </div>
      </section>

      <aside class="dashboard-card">
        <div class="section-head">
          <h2>Notifications</h2>
        </div>

        <% if (notifications.length === 0) { %>
          <p class="empty-state">Aucune notification.</p>
        <% } else { %>
          <div class="notifications-list compact">
            <% notifications.forEach((notification) => { %>
              <article class="notification-item <%= notification.is_read ? 'is-read' : 'is-unread' %>">
                <div class="notification-meta">
                  <span><%= resolveNotificationTargetLabel(notification.target_role) %></span>
                  <span><%= notification.created_at.slice(0, 10) %></span>
                </div>
                <h3><%= notification.title %></h3>
                <p><%= notification.message %></p>
              </article>
            <% }) %>
          </div>

          <a href="/notifications" class="ghost-button button-link">Voir toutes les notifications</a>
        <% } %>

        <div class="section-head compact">
          <h2>Modifier le pseudo</h2>
        </div>

        <form action="/account/username" method="post" class="stack-form">
          <label class="field">
            <span>Nouveau pseudo</span>
            <input type="text" name="username" value="<%= user.username %>" minlength="3" maxlength="30" required />
          </label>

          <button type="submit" class="ghost-button">Mettre a jour le pseudo</button>
        </form>

        <div class="section-head compact">
          <h2>Changer le mot de passe</h2>
        </div>

        <form action="/account/password" method="post" class="stack-form">
          <label class="field">
            <span>Mot de passe actuel</span>
            <input type="password" name="currentPassword" required />
          </label>

          <label class="field">
            <span>Nouveau mot de passe</span>
            <input type="password" name="newPassword" minlength="8" required />
          </label>

          <label class="field">
            <span>Confirmation</span>
            <input type="password" name="confirmNewPassword" minlength="8" required />
          </label>

          <button type="submit" class="primary-button">Mettre a jour</button>
        </form>
      </aside>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
