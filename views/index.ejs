<%- include("partials/head", { pageTitle }) %>
<%- include("partials/header") %>

<main>
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Pilotage attraction</span>
        <h1>Le calculateur de debit devient le centre de l'experience.</h1>
        <p class="hero-text">
          Saisis rapidement les donnees utiles, lis le resultat instantanement et enregistre un
          calcul propre dans un outil plus direct, plus lisible et plus agreable a utiliser.
        </p>

        <% if (!user) { %>
          <div class="limit-pill">
            <strong>Visiteur :</strong> <span><%= anonymousDailyCount %>/2 calculs aujourd'hui</span>
          </div>
        <% } else if (!user.isAdmin) { %>
          <div class="limit-pill">
            <strong>Compte actif :</strong> <span>calculs illimites + historique personnel</span>
          </div>
        <% } else { %>
          <div class="limit-pill">
            <strong>Mode admin :</strong> <span>tableau Excel, moderation et bannissement IP</span>
          </div>
        <% } %>
      </div>

      <div class="hero-stage">
        <div class="hero-card">
          <%- include("partials/flash") %>

          <div class="panel-grid">
            <form action="/calculate" method="post" class="calculator-card" data-calculator-form>
              <div class="section-head">
                <h2>Saisie du calcul</h2>
                <p>Toutes les cases doivent etre remplies avant validation.</p>
              </div>

              <div class="formula-banner">
                <span>Formule active</span>
                <strong>personnes x 30 x trains / 2 min</strong>
              </div>

              <div class="hero-actions">
                <% if (!user) { %>
                  <a href="/register" class="primary-button button-link">Creer un compte</a>
                  <a href="/login" class="ghost-button button-link">Connexion</a>
                <% } else if (user.isAdmin) { %>
                  <a href="/admin" class="primary-button button-link">Ouvrir l'admin</a>
                  <a href="/" class="ghost-button button-link">Nouveau calcul</a>
                <% } else { %>
                  <a href="/dashboard" class="primary-button button-link">Voir mon historique</a>
                  <a href="/" class="ghost-button button-link">Nouveau calcul</a>
                <% } %>
              </div>

              <label class="field">
                <span>Nom de l'attraction</span>
                <input
                  type="text"
                  name="attractionName"
                  maxlength="80"
                  minlength="3"
                  required
                  placeholder="Ex. Dragon Rush"
                  data-attraction-input
                />
              </label>

              <div class="field-split">
                <label class="field">
                  <span>Personnes par train</span>
                  <input
                    type="number"
                    name="peoplePerTrain"
                    min="1"
                    max="100"
                    required
                    placeholder="Ex. 24"
                    data-people-input
                  />
                </label>

                <label class="field">
                  <span>Trains en 2 minutes</span>
                  <input
                    type="number"
                    name="trainsInTwoMinutes"
                    min="1"
                    max="50"
                    required
                    placeholder="Ex. 3"
                    data-trains-input
                  />
                </label>
              </div>

              <button type="submit" class="primary-button" disabled data-submit-button>
                Enregistrer le calcul
              </button>
            </form>

            <aside class="result-card" aria-live="polite">
              <div class="section-head">
                <h2>Resultat a droite</h2>
                <p>Lecture immediate du debit horaire avant enregistrement.</p>
              </div>

              <div class="result-badge">Simulation temps reel</div>

              <div class="result-metric">
                <span data-result-attraction>
                  <%= lastCalculation ? lastCalculation.attractionName : "Attraction en attente" %>
                </span>
                <strong data-result-value>
                  <%= lastCalculation ? `${lastCalculation.throughput} pers/heure` : "-- pers/heure" %>
                </strong>
              </div>

              <dl class="result-details">
                <div>
                  <dt>Personnes / train</dt>
                  <dd data-result-people><%= lastCalculation ? lastCalculation.peoplePerTrain : "--" %></dd>
                </div>
                <div>
                  <dt>Trains / 2 min</dt>
                  <dd data-result-trains><%= lastCalculation ? lastCalculation.trainsInTwoMinutes : "--" %></dd>
                </div>
                <div>
                  <dt>Statut</dt>
                  <dd data-result-status>Completez les champs pour activer le calcul.</dd>
                </div>
              </dl>

              <div class="result-note">
                Le resultat s'actualise a chaque saisie pour une lecture plus fluide.
              </div>

              <div class="result-mini-stats">
                <article>
                  <span>Lecture</span>
                  <strong>Instantanee</strong>
                </article>
                <article>
                  <span>Saisie</span>
                  <strong>Controlee</strong>
                </article>
                <article>
                  <span>Export</span>
                  <strong>Admin</strong>
                </article>
              </div>
            </aside>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
