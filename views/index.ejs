<%- include("partials/head", {
  pageTitle,
  seoTitle: t("home.title") + " | Roller Flow",
  seoDescription: t("home.seoBlock1P1")
}) %>
<%- include("partials/header") %>

<main>
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="hero-copy-shell">
          <div class="section-head hero-head">
            <span class="eyebrow"><%= t("home.version") %></span>
            <h1><%= t("home.title") %></h1>
            <p><%= t("home.intro") %></p>
          </div>

          <div class="hero-summary-grid">
            <% if (!user) { %>
              <div class="summary-card">
                <span class="summary-label"><%= t("home.visitor") %></span>
                <strong><%= t("home.visitorCount", { count: anonymousDailyCount }) %></strong>
              </div>
            <% } %>
          </div>

          <div class="hero-actions hero-actions-stack">
            <% if (!user) { %>
              <a href="/register" class="primary-button button-link"><%= t("home.createAccount") %></a>
              <a href="/login" class="ghost-button button-link"><%= t("nav.login") %></a>
            <% } else { %>
              <a href="/dashboard" class="primary-button button-link"><%= t("home.myHistory") %></a>
            <% } %>
          </div>
        </div>
      </div>

      <div class="hero-stage">
        <div class="hero-card">
          <%- include("partials/flash") %>

          <div class="panel-grid">
            <form
              action="/calculate"
              method="post"
              class="calculator-card"
              data-calculator-form
              data-text-attraction-name="<%= t('home.attractionName') %>"
              data-text-attraction-search="<%= t('home.attractionSearch') %>"
              data-text-attraction-help="<%= t('home.attractionHelp') %>"
              data-text-attraction-auto-help="<%= t('home.attractionAutoHelp') %>"
              data-text-people-help="<%= t('home.peopleHelp') %>"
              data-text-people-auto-help="<%= t('home.peopleAutoHelp') %>"
              data-text-select-attraction="<%= t('home.selectAttractionThenTrains') %>"
              data-text-fill-all-fields="<%= t('home.fillAllFields') %>"
              data-text-click-submit="<%= t('home.clickToShowResult') %>"
              data-text-search-loading="<%= t('home.searchLoading') %>"
              data-text-search-no-result="<%= t('home.searchNoResult') %>"
              data-text-search-no-result-body="<%= t('home.searchNoResultText') %>"
              data-text-search-suggestion-singular="<%= currentLang === 'en' ? 'suggestion' : 'proposition' %>"
              data-text-search-suggestion-plural="<%= currentLang === 'en' ? 'suggestions' : 'propositions' %>"
              data-text-waiting-ride="<%= t('home.waitingRide') %>"
            >
              <input type="hidden" name="calculationMode" value="manual" data-mode-input />
              <input type="hidden" name="catalogAttractionId" value="" data-catalog-id-input />

              <div class="section-head">
                <h2><%= t("home.formTitle") %></h2>
              </div>

              <div class="mode-switch" data-mode-switch>
                <button type="button" class="mode-button is-active" data-mode-button data-mode-value="manual">
                  <%= t("home.manual") %>
                </button>
                <button
                  type="button"
                  class="mode-button"
                  data-mode-button
                  data-mode-value="auto"
                  <%= !user || !catalogInfo.available ? "disabled" : "" %>
                >
                  <%= t("home.auto") %>
                </button>
              </div>

              <div class="catalog-state">
                <% if (!user) { %>
                  <span><%= t("home.autoLoginRequired") %></span>
                <% } else if (!catalogInfo.available) { %>
                  <span><%= t("home.autoMissingFile") %></span>
                <% } else { %>
                  <span><%= t("home.autoAvailable") %></span>
                <% } %>
              </div>

              <% if (user) { %>
                <a href="/attraction-requests/new" class="request-link"><%= t("home.requestMissingRide") %></a>
              <% } %>

              <label class="field">
                <span data-attraction-label><%= t("home.attractionName") %></span>
                <input
                  type="text"
                  name="attractionName"
                  maxlength="80"
                  minlength="3"
                  required
                  placeholder="<%= t('home.attractionPlaceholder') %>"
                  autocomplete="off"
                  data-attraction-input
                />
                <small class="field-help" data-attraction-help>
                  <%= t("home.attractionHelp") %>
                </small>
                <div class="search-panel" data-search-panel hidden>
                  <div class="search-panel-head">
                    <span><%= t("home.results") %></span>
                    <small data-search-meta><%= t("home.startTyping") %></small>
                  </div>
                  <div class="search-results" data-search-results></div>
                </div>
              </label>

              <div class="field-split">
                <label class="field">
                  <span><%= t("home.peoplePerTrain") %></span>
                  <input
                    type="number"
                    name="peoplePerTrain"
                    min="1"
                    max="100"
                    required
                    placeholder="<%= t('home.peoplePlaceholder') %>"
                    data-people-input
                  />
                  <small class="field-help" data-people-help>
                    <%= t("home.peopleHelp") %>
                  </small>
                </label>

                <label class="field">
                  <span><%= t("home.trainsInTwoMinutes") %></span>
                  <input
                    type="number"
                    name="trainsInTwoMinutes"
                    min="1"
                    max="50"
                    required
                    placeholder="<%= t('home.trainsPlaceholder') %>"
                    data-trains-input
                  />
                </label>
              </div>

              <button type="submit" class="primary-button" disabled data-submit-button>
                <%= t("home.submit") %>
              </button>
            </form>

            <aside class="result-card" aria-live="polite">
              <div class="section-head">
                <h2><%= t("home.result") %></h2>
                <p><%= t("home.resultIntro") %></p>
              </div>

              <div class="result-badge"><%= t("home.lastCalculation") %></div>

              <div class="result-metric">
                <span data-result-attraction>
                  <%= lastCalculation ? lastCalculation.attractionName : t("home.waitingRide") %>
                </span>
                <strong data-result-value>
                  <%= lastCalculation ? `${lastCalculation.throughput} ${t("home.peopleHour")}` : `-- ${t("home.peopleHour")}` %>
                </strong>
              </div>

              <dl class="result-details">
                <div>
                  <dt><%= t("home.peopleTrain") %></dt>
                  <dd data-result-people><%= lastCalculation ? lastCalculation.peoplePerTrain : "--" %></dd>
                </div>
                <div>
                  <dt><%= t("home.trains2min") %></dt>
                  <dd data-result-trains><%= lastCalculation ? lastCalculation.trainsInTwoMinutes : "--" %></dd>
                </div>
                <div>
                  <dt><%= t("home.status") %></dt>
                  <dd data-result-status><%= t("home.fillThenSubmit") %></dd>
                </div>
              </dl>

            </aside>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container seo-section">
    <div class="dashboard-card content-card">
      <article class="content-block">
        <h2><%= t("home.seoBlock1Title") %></h2>
        <p><%= t("home.seoBlock1P1") %></p>
        <p><%= t("home.seoBlock1P2") %></p>
      </article>

      <article class="content-block">
        <h2><%= t("home.seoBlock2Title") %></h2>
        <p><%= t("home.seoBlock2P1") %></p>
        <p><%= t("home.seoBlock2P2") %></p>
      </article>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
