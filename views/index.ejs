<%- include("partials/head", { pageTitle }) %>
<%- include("partials/header") %>

<main>
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1>Calculateur de debit</h1>

        <% if (!user) { %>
          <div class="limit-pill">
            <strong>Visiteur :</strong> <span><%= anonymousDailyCount %>/2 calculs aujourd'hui</span>
          </div>
        <% } else if (!user.isAdmin) { %>
          <div class="limit-pill">
            <strong>Compte :</strong> <span>calculs illimites</span>
          </div>
        <% } else { %>
          <div class="limit-pill">
            <strong>Compte :</strong> <span>gestion</span>
          </div>
        <% } %>
      </div>

      <div class="hero-stage">
        <div class="hero-card">
          <%- include("partials/flash") %>

          <div class="panel-grid">
            <form action="/calculate" method="post" class="calculator-card" data-calculator-form>
              <div class="section-head">
                <h2>Saisie du calcul</h2>
              </div>

              <div class="formula-banner">
                <span>Formule</span>
                <strong>personnes x 30 x trains en 2 min</strong>
              </div>

              <div class="hero-actions">
                <% if (!user) { %>
                  <a href="/register" class="primary-button button-link">Creer un compte</a>
                  <a href="/login" class="ghost-button button-link">Connexion</a>
                <% } else if (user.isAdmin) { %>
                  <a href="/admin" class="primary-button button-link">Gestion</a>
                  <a href="/" class="ghost-button button-link">Nouveau calcul</a>
                <% } else { %>
                  <a href="/dashboard" class="primary-button button-link">Mon historique</a>
                  <a href="/" class="ghost-button button-link">Nouveau calcul</a>
                <% } %>
              </div>

              <label class="field">
                <span>Nom de l'attraction</span>
                <input
                  type="text"
                  name="attractionName"
                  maxlength="80"
                  minlength="3"
                  required
                  placeholder="Ex. Dragon Rush"
                  data-attraction-input
                />
              </label>

              <div class="field-split">
                <label class="field">
                  <span>Personnes par train</span>
                  <input
                    type="number"
                    name="peoplePerTrain"
                    min="1"
                    max="100"
                    required
                    placeholder="Ex. 24"
                    data-people-input
                  />
                </label>

                <label class="field">
                  <span>Trains en 2 minutes</span>
                  <input
                    type="number"
                    name="trainsInTwoMinutes"
                    min="1"
                    max="50"
                    required
                    placeholder="Ex. 3"
                    data-trains-input
                  />
                </label>
              </div>

              <button type="submit" class="primary-button" disabled data-submit-button>
                Enregistrer le calcul
              </button>
            </form>

            <aside class="result-card" aria-live="polite">
              <div class="section-head">
                <h2>Resultat</h2>
              </div>

              <div class="result-badge">Dernier calcul</div>

              <div class="result-metric">
                <span data-result-attraction>
                  <%= lastCalculation ? lastCalculation.attractionName : "Attraction en attente" %>
                </span>
                <strong data-result-value>
                  <%= lastCalculation ? `${lastCalculation.throughput} pers/heure` : "-- pers/heure" %>
                </strong>
              </div>

              <dl class="result-details">
                <div>
                  <dt>Personnes / train</dt>
                  <dd data-result-people><%= lastCalculation ? lastCalculation.peoplePerTrain : "--" %></dd>
                </div>
                <div>
                  <dt>Trains / 2 min</dt>
                  <dd data-result-trains><%= lastCalculation ? lastCalculation.trainsInTwoMinutes : "--" %></dd>
                </div>
                <div>
                  <dt>Statut</dt>
                  <dd data-result-status>Remplissez les champs puis validez.</dd>
                </div>
              </dl>

            </aside>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
