<%- include("partials/head", {
  pageTitle,
  seoTitle: "Calculateur de debit roller coaster | Roller Flow",
  seoDescription: "Calculez le debit horaire d'une attraction avec un mode manuel ou auto, un historique personnel et une gestion simple des demandes d'ajout."
}) %>
<%- include("partials/header") %>

<main>
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="hero-copy-shell">
          <div class="section-head hero-head">
            <span class="eyebrow">Version 1</span>
            <h1>Calculateur de debit</h1>
            <p>Choisissez votre mode, validez le calcul et retrouvez-le ensuite dans votre historique.</p>
          </div>

          <div class="hero-summary-grid">
            <% if (!user) { %>
              <div class="summary-card">
                <span class="summary-label">Visiteur</span>
                <strong><%= anonymousDailyCount %>/2 calculs</strong>
              </div>
            <% } else { %>
              <div class="summary-card">
                <span class="summary-label">Compte</span>
                <strong>Calculs illimites</strong>
              </div>
            <% } %>

            <div class="summary-card">
              <span class="summary-label">Formule</span>
              <strong>personnes x 30 x trains en 2 min</strong>
            </div>
          </div>

          <div class="hero-actions hero-actions-stack">
            <% if (!user) { %>
              <a href="/register" class="primary-button button-link">Creer un compte</a>
              <a href="/login" class="ghost-button button-link">Connexion</a>
            <% } else { %>
              <a href="/dashboard" class="primary-button button-link">Mon historique</a>
              <a href="/" class="ghost-button button-link">Nouveau calcul</a>
            <% } %>
          </div>
        </div>
      </div>

      <div class="hero-stage">
        <div class="hero-card">
          <%- include("partials/flash") %>

          <div class="panel-grid">
            <form action="/calculate" method="post" class="calculator-card" data-calculator-form>
              <input type="hidden" name="calculationMode" value="manual" data-mode-input />
              <input type="hidden" name="catalogAttractionId" value="" data-catalog-id-input />

              <div class="section-head">
                <h2>Saisie du calcul</h2>
              </div>

              <div class="mode-switch" data-mode-switch>
                <button type="button" class="mode-button is-active" data-mode-button data-mode-value="manual">
                  Manuel
                </button>
                <button
                  type="button"
                  class="mode-button"
                  data-mode-button
                  data-mode-value="auto"
                  <%= !user || !catalogInfo.available ? "disabled" : "" %>
                >
                  Auto
                </button>
              </div>

              <div class="catalog-state">
                <% if (!user) { %>
                  <span>Connectez-vous pour utiliser le mode auto.</span>
                <% } else if (catalogInfo.available) { %>
                  <span><%= catalogInfo.total %> attractions chargees depuis le fichier Excel.</span>
                <% } else { %>
                  <span>Ajoutez `data/attractions.xlsx` pour activer le mode auto.</span>
                <% } %>
              </div>

              <% if (user) { %>
                <a href="/attraction-requests/new" class="request-link">Pas trouve ? Cliquez ici</a>
              <% } %>

              <label class="field">
                <span data-attraction-label>Nom de l'attraction</span>
                <input
                  type="text"
                  name="attractionName"
                  maxlength="80"
                  minlength="3"
                  required
                  placeholder="Ex. Dragon Rush"
                  autocomplete="off"
                  data-attraction-input
                />
                <small class="field-help" data-attraction-help>
                  Saisissez librement le nom de l'attraction.
                </small>
                <div class="search-results" data-search-results hidden></div>
              </label>

              <div class="field-split">
                <label class="field">
                  <span>Personnes par train</span>
                  <input
                    type="number"
                    name="peoplePerTrain"
                    min="1"
                    max="100"
                    required
                    placeholder="Ex. 24"
                    data-people-input
                  />
                  <small class="field-help" data-people-help>
                    Entrez manuellement la capacite d'un train.
                  </small>
                </label>

                <label class="field">
                  <span>Trains en 2 minutes</span>
                  <input
                    type="number"
                    name="trainsInTwoMinutes"
                    min="1"
                    max="50"
                    required
                    placeholder="Ex. 3"
                    data-trains-input
                  />
                </label>
              </div>

              <button type="submit" class="primary-button" disabled data-submit-button>
                Enregistrer le calcul
              </button>
            </form>

            <aside class="result-card" aria-live="polite">
              <div class="section-head">
                <h2>Resultat</h2>
                <p>Le dernier calcul valide reste affiche ici.</p>
              </div>

              <div class="result-badge">Dernier calcul</div>

              <div class="result-metric">
                <span data-result-attraction>
                  <%= lastCalculation ? lastCalculation.attractionName : "Attraction en attente" %>
                </span>
                <strong data-result-value>
                  <%= lastCalculation ? `${lastCalculation.throughput} pers/heure` : "-- pers/heure" %>
                </strong>
              </div>

              <dl class="result-details">
                <div>
                  <dt>Personnes / train</dt>
                  <dd data-result-people><%= lastCalculation ? lastCalculation.peoplePerTrain : "--" %></dd>
                </div>
                <div>
                  <dt>Trains / 2 min</dt>
                  <dd data-result-trains><%= lastCalculation ? lastCalculation.trainsInTwoMinutes : "--" %></dd>
                </div>
                <div>
                  <dt>Statut</dt>
                  <dd data-result-status>Remplissez les champs puis validez.</dd>
                </div>
              </dl>

            </aside>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container seo-section">
    <div class="dashboard-card content-card">
      <article class="content-block">
        <h2>Calculer le debit d'un roller coaster</h2>
        <p>
          Roller Flow permet de calculer rapidement le debit horaire d'une attraction a partir du nombre
          de personnes par train et du nombre de trains qui passent en deux minutes.
        </p>
        <p>
          L'outil est pense pour un usage simple sur ordinateur ou mobile, avec un historique personnel,
          un mode manuel et un mode auto base sur un catalogue d'attractions.
        </p>
      </article>

      <article class="content-block">
        <h2>Formule de calcul</h2>
        <p>
          La formule utilisee est : personnes par train x 30 x nombre de trains en 2 minutes. Le resultat
          donne une estimation du debit par heure.
        </p>
        <p>
          Cette base est utile pour comparer l'exploitation de plusieurs attractions, suivre une capacite
          theorique et centraliser les calculs dans un seul espace.
        </p>
      </article>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
