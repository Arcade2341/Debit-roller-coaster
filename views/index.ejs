<%- include("partials/head", {
  pageTitle,
  seoTitle: t("home.title") + " | Roller Flow",
  seoDescription: t("home.seoBlock1P1")
}) %>
<%- include("partials/header") %>

<main>
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-stage">
        <div class="hero-card">
          <%- include("partials/flash") %>

          <div class="panel-grid">
            <form
              action="/calculate"
              method="post"
              class="calculator-card"
              data-calculator-form
              data-text-attraction-name="<%= t('home.attractionName') %>"
              data-text-attraction-search="<%= t('home.attractionSearch') %>"
              data-text-attraction-help="<%= t('home.attractionHelp') %>"
              data-text-select-attraction="<%= t('home.selectAttractionThenTimes') %>"
              data-text-fill-all-fields="<%= t('home.fillAllFields') %>"
              data-text-click-submit="<%= t('home.clickToShowResult') %>"
              data-text-search-loading="<%= t('home.searchLoading') %>"
              data-text-search-no-result="<%= t('home.searchNoResult') %>"
              data-text-search-no-result-body="<%= t('home.searchNoResultText') %>"
              data-text-search-suggestion-singular="<%= currentLang === 'en' ? 'suggestion' : 'proposition' %>"
              data-text-search-suggestion-plural="<%= currentLang === 'en' ? 'suggestions' : 'propositions' %>"
              data-text-waiting-ride="<%= t('home.waitingRide') %>"
              data-text-people-train-short="<%= t('home.peopleTrainShort') %>"
              data-text-time-label="<%= t('home.dispatchTimeLabel') %>"
              data-text-average-seconds="<%= t('home.averageSeconds') %>"
              data-text-chrono-start="<%= t('home.chronoStart') %>"
              data-text-chrono-stop="<%= t('home.chronoStop') %>"
              data-text-chrono-plus-one="<%= t('home.chronoPlusOne') %>"
              data-text-chrono-help="<%= t('home.chronoHelp') %>"
              data-text-chrono-empty="<%= t('home.chronoEmpty') %>"
              data-text-chrono-running="<%= t('home.chronoRunning') %>"
            >
              <input type="hidden" name="catalogAttractionId" value="" data-catalog-id-input />

              <div class="section-head">
                <h2><%= t("home.formTitle") %></h2>
              </div>

              <% if (!catalogInfo.available) { %>
                <div class="catalog-state">
                  <span><%= t("home.autoMissingFile") %></span>
                </div>
              <% } %>

              <div class="input-section-card" data-search-block>
                <div class="mini-section-head">
                  <h3><%= t("home.rideSectionTitle") %></h3>
                  <p><%= t("home.rideSectionText") %></p>
                </div>
                <label class="field">
                  <span><%= t("home.attractionSearch") %></span>
                  <input
                    type="text"
                    name="attractionName"
                    maxlength="80"
                    minlength="3"
                    required
                    placeholder="<%= t('home.attractionPlaceholder') %>"
                    autocomplete="off"
                    data-attraction-input
                  />
                  <small class="field-help">
                    <%= t("home.attractionHelp") %>
                  </small>
                  <div class="search-panel" data-search-panel hidden>
                    <div class="search-panel-head">
                      <span><%= t("home.results") %></span>
                      <small data-search-meta><%= t("home.startTyping") %></small>
                    </div>
                    <div class="search-results" data-search-results></div>
                  </div>
                </label>
              </div>

              <div class="chrono-panel" data-chrono-panel>
                <div class="mini-section-head">
                  <h3><%= t("home.chronoSectionTitle") %></h3>
                  <p><%= t("home.chronoSectionText") %></p>
                </div>
                <div class="chrono-display" data-chrono-display>00:00</div>
                <div class="chrono-controls">
                  <button type="button" class="primary-button chrono-start-button" data-chrono-start-button>
                    <%= t("home.chronoStart") %>
                  </button>
                  <div class="chrono-running-controls" data-chrono-running-controls hidden>
                    <button type="button" class="ghost-button chrono-stop-button" data-chrono-stop-button>
                      <%= t("home.chronoStop") %>
                    </button>
                    <button type="button" class="primary-button chrono-lap-button" data-chrono-lap-button>
                      <%= t("home.chronoPlusOne") %>
                    </button>
                  </div>
                </div>
                <div class="chrono-times-list" data-chrono-times-list>
                  <p class="empty-state" data-chrono-empty><%= t("home.chronoEmpty") %></p>
                </div>
                <div data-chrono-hidden-inputs></div>
                <small class="field-help" data-chrono-help><%= t("home.chronoHelp") %></small>
              </div>

              <% if (user) { %>
                <a href="/attraction-requests/new" class="request-link" data-request-link><%= t("home.requestMissingRide") %></a>
              <% } %>

              <div class="calculator-actions">
                <button type="submit" class="primary-button" disabled data-submit-button>
                  <%= t("home.submit") %>
                </button>
              </div>
            </form>

            <aside class="result-card" aria-live="polite">
              <div class="result-shell">
                <div class="section-head">
                  <h2><%= t("home.result") %></h2>
                  <p><%= t("home.resultIntro") %></p>
                </div>

                <div class="result-badge"><%= t("home.lastCalculation") %></div>

                <div class="result-hero">
                  <div class="result-metric">
                    <span data-result-attraction>
                      <%= lastCalculation ? lastCalculation.attractionName : t("home.waitingRide") %>
                    </span>
                    <strong data-result-value>
                      <%= lastCalculation ? `${lastCalculation.throughput} ${t("home.peopleHour")}` : `-- ${t("home.peopleHour")}` %>
                    </strong>
                  </div>
                </div>

                <dl class="result-stats-grid">
                  <div class="result-stat-card">
                    <dt><%= t("home.peopleTrain") %></dt>
                    <dd data-result-people><%= lastCalculation ? lastCalculation.peoplePerTrain : "--" %></dd>
                  </div>
                  <div class="result-stat-card">
                    <dt><%= t("home.averageSeconds") %></dt>
                    <dd data-result-average><%= lastCalculation ? lastCalculation.averageDispatchSeconds : "--" %></dd>
                  </div>
                  <div class="result-stat-card">
                    <dt><%= t("home.samples") %></dt>
                    <dd data-result-samples><%= lastCalculation ? lastCalculation.timeSamplesCount : "--" %></dd>
                  </div>
                </dl>

                <div class="result-status-card">
                  <span><%= t("home.status") %></span>
                  <strong data-result-status><%= t("home.fillThenSubmit") %></strong>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container seo-section">
    <div class="dashboard-card content-card">
      <article class="content-block">
        <h2><%= t("home.seoBlock1Title") %></h2>
        <p><%= t("home.seoBlock1P1") %></p>
        <p><%= t("home.seoBlock1P2") %></p>
      </article>

      <article class="content-block">
        <h2><%= t("home.seoBlock2Title") %></h2>
        <p><%= t("home.seoBlock2P1") %></p>
        <p><%= t("home.seoBlock2P2") %></p>
      </article>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
