<%- include("partials/head", { pageTitle, metaRobots: "noindex,nofollow" }) %>
<%- include("partials/header") %>

<main class="auth-page">
  <section class="container form-page">
    <div class="form-shell">
      <div class="section-head">
        <span class="eyebrow"><%= t("auth.loginEyebrow") %></span>
        <h1><%= t("auth.loginTitle") %></h1>
        <p><%= t("auth.loginIntro") %></p>
      </div>

      <%- include("partials/flash") %>

      <form action="/login" method="post" class="stack-form">
        <label class="field">
          <span><%= t("auth.username") %></span>
          <input type="text" name="username" minlength="3" maxlength="30" required />
        </label>

        <label class="field">
          <span><%= t("auth.password") %></span>
          <input type="password" name="password" required />
        </label>

        <button type="submit" class="primary-button"><%= t("auth.loginButton") %></button>
      </form>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
