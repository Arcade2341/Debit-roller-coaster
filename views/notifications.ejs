<%- include("partials/head", { pageTitle, metaRobots: "noindex,nofollow" }) %>
<%- include("partials/header") %>

<main class="dashboard-page">
  <section class="container">
    <div class="page-intro">
      <div class="section-head">
        <h1><%= t("notifications.title") %></h1>
        <p><%= t("notifications.intro") %></p>
      </div>
    </div>

    <%- include("partials/flash") %>

    <div class="notification-center-grid">
      <section class="dashboard-card">
        <div class="section-head">
          <h2><%= t("notifications.feed") %></h2>
          <p><%= t("notifications.feedIntro") %></p>
        </div>

        <% if (notifications.length > 0) { %>
          <form action="/notifications/read-all" method="post" class="notifications-toolbar">
            <button type="submit" class="ghost-button"><%= t("notifications.markAllRead") %></button>
          </form>
        <% } %>

        <% if (feedItems.length === 0) { %>
          <p class="empty-state"><%= t("notifications.feedEmpty") %></p>
        <% } else { %>
          <div class="notifications-list">
            <% feedItems.forEach((item) => { %>
              <article class="notification-item notification-feed-item <%= item.kind === 'notification' && !item.isRead ? 'is-unread' : 'is-read' %>">
                <div class="notification-meta">
                  <% item.pills.forEach((pill) => { %>
                    <span><%= pill %></span>
                  <% }) %>
                  <span><%= item.publishedAt.slice(0, 16).replace("T", " ") %></span>
                  <span><%= item.author %></span>
                </div>

                <h2><%= item.title %></h2>

                <% if (item.summary) { %>
                  <p class="news-summary"><%= item.summary %></p>
                <% } %>

                <p><%= item.body %></p>

                <% if (item.kind === "notification" && !item.isRead) { %>
                  <form action="/notifications/<%= item.readActionId %>/read" method="post">
                    <button type="submit" class="history-delete-button"><%= t("notifications.markRead") %></button>
                  </form>
                <% } %>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>

      <aside class="dashboard-card notification-side-panel">
        <div class="section-head">
          <h2><%= t("notifications.activePolls") %></h2>
          <p><%= t("notifications.activePollsIntro") %></p>
        </div>

        <% if (polls.length === 0) { %>
          <p class="empty-state"><%= t("polls.none") %></p>
        <% } else { %>
          <div class="notifications-list compact">
            <% polls.forEach((poll) => { %>
              <article class="notification-item poll-card">
                <div class="notification-meta">
                  <span><%= t("publication.typePoll") %></span>
                  <span><%= poll.allow_multiple ? t("polls.multipleChoice") : t("polls.singleChoice") %></span>
                  <span><%= poll.published_at.slice(0, 16).replace("T", " ") %></span>
                </div>

                <h3><%= poll.title %></h3>
                <p><%= poll.question %></p>

                <form action="/polls/<%= poll.id %>/respond" method="post" class="stack-form">
                  <% poll.options.forEach((option) => { %>
                    <label class="consent-check poll-option-row">
                      <input
                        type="<%= poll.allow_multiple ? 'checkbox' : 'radio' %>"
                        name="optionIds"
                        value="<%= option.id %>"
                        <%= poll.selectedOptionIds.includes(option.id) ? 'checked' : '' %>
                      />
                      <span><%= option.label %></span>
                      <strong class="poll-option-count"><%= option.votes %></strong>
                    </label>
                  <% }) %>

                  <button type="submit" class="primary-button"><%= t("polls.answer") %></button>
                </form>
              </article>
            <% }) %>
          </div>
        <% } %>
      </aside>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
