<%- include("partials/head", { pageTitle, metaRobots: "noindex,nofollow" }) %>
<%- include("partials/header") %>

<main class="dashboard-page">
  <section class="container">
    <div class="page-intro">
      <div class="section-head">
        <h1><%= t("notifications.title") %></h1>
        <p><%= t("notifications.intro") %></p>
      </div>
    </div>

    <section class="dashboard-card">
        <div class="section-head">
          <h2><%= t("notifications.inbox") %></h2>
          <p><%= t("notifications.inboxIntro") %></p>
        </div>

        <%- include("partials/flash") %>

        <% if (notifications.length === 0) { %>
          <p class="empty-state"><%= t("notifications.none") %></p>
        <% } else { %>
          <form action="/notifications/read-all" method="post" class="notifications-toolbar">
            <button type="submit" class="ghost-button"><%= t("notifications.markAllRead") %></button>
          </form>

          <div class="notifications-list">
            <% notifications.forEach((notification) => { %>
              <article class="notification-item <%= notification.is_read ? 'is-read' : 'is-unread' %>">
                <div class="notification-meta">
                  <span><%= resolveNotificationCategoryLabel(notification.category) %></span>
                  <span><%= resolveNotificationTargetLabel(notification.target_role) %></span>
                  <span><%= notification.created_at.slice(0, 10) %></span>
                  <span><%= notification.sender_username || t("notifications.system") %></span>
                </div>

                <h2><%= notification.title %></h2>
                <p><%= notification.message %></p>

                <% if (!notification.is_read) { %>
                  <form action="/notifications/<%= notification.id %>/read" method="post">
                    <button type="submit" class="history-delete-button"><%= t("notifications.markRead") %></button>
                  </form>
                <% } %>
              </article>
            <% }) %>
          </div>
        <% } %>

        <div class="section-head compact">
          <h2><%= t("news.title") %></h2>
          <p><%= t("news.intro") %></p>
        </div>

        <% if (newsPosts.length === 0) { %>
          <p class="empty-state"><%= t("news.none") %></p>
        <% } else { %>
          <div class="notifications-list compact">
            <% newsPosts.forEach((post) => { %>
              <article class="notification-item">
                <div class="notification-meta">
                  <span><%= post.created_at.slice(0, 10) %></span>
                  <span><%= post.author_username || t("notifications.system") %></span>
                </div>
                <h2><%= post.title %></h2>
                <p class="news-summary"><%= post.summary %></p>
                <p><%= post.content %></p>
              </article>
            <% }) %>
          </div>
        <% } %>

        <div class="section-head compact">
          <h2><%= t("polls.title") %></h2>
          <p><%= t("polls.intro") %></p>
        </div>

        <% if (polls.length === 0) { %>
          <p class="empty-state"><%= t("polls.none") %></p>
        <% } else { %>
          <div class="notifications-list compact">
            <% polls.forEach((poll) => { %>
              <article class="notification-item">
                <div class="notification-meta">
                  <span><%= poll.allow_multiple ? t("polls.multipleChoice") : t("polls.singleChoice") %></span>
                  <span><%= poll.created_at.slice(0, 10) %></span>
                </div>
                <h2><%= poll.title %></h2>
                <p><%= poll.question %></p>
                <form action="/polls/<%= poll.id %>/respond" method="post" class="stack-form">
                  <% poll.options.forEach((option) => { %>
                    <label class="consent-check">
                      <input
                        type="<%= poll.allow_multiple ? 'checkbox' : 'radio' %>"
                        name="optionIds"
                        value="<%= option.id %>"
                        <%= poll.selectedOptionIds.includes(option.id) ? 'checked' : '' %>
                      />
                      <span><%= option.label %> (<%= option.votes %>)</span>
                    </label>
                  <% }) %>
                  <button type="submit" class="ghost-button"><%= t("polls.answer") %></button>
                </form>
              </article>
            <% }) %>
          </div>
        <% } %>
    </section>
  </section>
</main>

<%- include("partials/footer") %>
