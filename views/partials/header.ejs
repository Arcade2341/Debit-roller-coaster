<header class="site-header">
  <div class="container nav-shell">
    <a class="brand" href="/">
      <span class="brand-mark">RC</span>
      <span class="brand-text">
        <strong><%= t("common.siteName") %></strong>
        <small><%= t("common.calculator") %></small>
      </span>
    </a>

    <button
      type="button"
      class="nav-menu-toggle"
      data-nav-toggle
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="<%= currentLang === 'en' ? 'Open menu' : 'Ouvrir le menu' %>"
      data-label-open="<%= currentLang === 'en' ? 'Open menu' : 'Ouvrir le menu' %>"
      data-label-close="<%= currentLang === 'en' ? 'Close menu' : 'Fermer le menu' %>"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav id="site-nav" class="nav-links" data-nav-links aria-label="<%= currentLang === 'en' ? 'Main navigation' : 'Navigation principale' %>">
      <a href="/" class="<%= currentPath === '/' ? 'is-active' : '' %>"><%= t("nav.calculate") %></a>
      <% if (user) { %>
        <a href="/notifications" class="<%= currentPath === '/notifications' ? 'is-active' : '' %>">
          <%= t("nav.notifications") %>
          <% if (unreadNotificationsCount > 0) { %>
            <span class="nav-badge"><%= unreadNotificationsCount %></span>
          <% } %>
        </a>
        <a href="/dashboard" class="<%= currentPath === '/dashboard' ? 'is-active' : '' %>"><%= t("nav.dashboard") %></a>
        <% if (user.isAdmin || user.isHelper) { %>
          <a href="/requests/review" class="<%= currentPath === '/requests/review' ? 'is-active' : '' %>"><%= t("nav.requests") %></a>
        <% } %>
        <% if (user.isAdmin) { %>
          <a href="/admin/accounts" class="<%= currentPath === '/admin/accounts' ? 'is-active' : '' %>"><%= t("nav.accounts") %></a>
        <% } %>
      <% } else { %>
        <a href="/login" class="<%= currentPath === '/login' ? 'is-active' : '' %>"><%= t("nav.login") %></a>
        <a href="/register" class="cta-link <%= currentPath === '/register' ? 'is-active' : '' %>"><%= t("nav.register") %></a>
      <% } %>
      <a href="/lang/fr" class="<%= currentLang === 'fr' ? 'is-active' : '' %>"><%= t("nav.languageFr") %></a>
      <a href="/lang/en" class="<%= currentLang === 'en' ? 'is-active' : '' %>"><%= t("nav.languageEn") %></a>
    </nav>
  </div>
</header>

<button
  type="button"
  class="theme-switch theme-switch-floating"
  data-theme-toggle
  aria-label="<%= t('common.darkMode') %>"
  data-label-dark="<%= t('common.darkMode') %>"
  data-label-light="<%= t('common.lightMode') %>"
  aria-pressed="false"
>
  <span class="theme-switch-track">
    <span class="theme-switch-thumb"></span>
  </span>
  <span class="theme-switch-label"><%= t("common.darkMode") %></span>
</button>
