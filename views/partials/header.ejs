<header class="site-header">
  <div class="container nav-shell">
    <a class="brand" href="/">
      <span class="brand-mark">RC</span>
      <span class="brand-text">
        <strong>Roller Flow</strong>
        <small>Calculateur</small>
      </span>
    </a>

    <nav class="nav-links" aria-label="Navigation principale">
      <a href="/" class="<%= currentPath === '/' ? 'is-active' : '' %>">Calcul</a>
      <% if (user) { %>
        <a href="/notifications" class="<%= currentPath === '/notifications' ? 'is-active' : '' %>">
          Notifications
          <% if (unreadNotificationsCount > 0) { %>
            <span class="nav-badge"><%= unreadNotificationsCount %></span>
          <% } %>
        </a>
        <a href="/dashboard" class="<%= currentPath === '/dashboard' ? 'is-active' : '' %>">Mon espace</a>
        <% if (user.isAdmin || user.isHelper) { %>
          <a href="/requests/review" class="<%= currentPath === '/requests/review' ? 'is-active' : '' %>">Demandes</a>
        <% } %>
        <% if (user.isAdmin) { %>
          <a href="/admin/accounts" class="<%= currentPath === '/admin/accounts' ? 'is-active' : '' %>">Comptes</a>
        <% } %>
      <% } else { %>
        <a href="/login" class="<%= currentPath === '/login' ? 'is-active' : '' %>">Connexion</a>
        <a href="/register" class="cta-link <%= currentPath === '/register' ? 'is-active' : '' %>">Creer un compte</a>
      <% } %>
    </nav>
  </div>
</header>

<button
  type="button"
  class="theme-switch theme-switch-floating"
  data-theme-toggle
  aria-label="Activer ou desactiver le mode sombre"
  aria-pressed="false"
>
  <span class="theme-switch-track">
    <span class="theme-switch-thumb"></span>
  </span>
  <span class="theme-switch-label">Mode sombre</span>
</button>
