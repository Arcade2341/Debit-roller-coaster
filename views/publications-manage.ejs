<%- include("partials/head", { pageTitle, metaRobots: "noindex,nofollow" }) %>
<%- include("partials/header") %>

<main class="dashboard-page">
  <section class="container">
    <div class="page-intro">
      <div class="section-head">
        <h1><%= t("publication.title") %></h1>
        <p><%= t("publication.intro") %></p>
      </div>
    </div>

    <%- include("partials/flash") %>

    <div class="dashboard-grid">
      <section class="dashboard-card">
        <div class="section-head">
          <h2><%= t("publication.new") %></h2>
          <p><%= t("publication.newIntro") %></p>
        </div>

        <form action="/publications/create" method="post" class="stack-form">
          <label class="field">
            <span><%= t("publication.type") %></span>
            <select name="type" class="field-select" required data-publication-type>
              <option value="notification"><%= t("publication.typeNotification") %></option>
              <option value="news"><%= t("publication.typeNews") %></option>
              <option value="poll"><%= t("publication.typePoll") %></option>
            </select>
          </label>

          <label class="field">
            <span><%= t("publication.titleField") %></span>
            <input type="text" name="title" minlength="3" maxlength="120" required />
          </label>

          <div data-publication-notification-fields>
            <label class="field">
              <span><%= t("admin.target") %></span>
              <select name="targetRole" class="field-select">
                <option value="all"><%= t("admin.allAccounts") %></option>
                <option value="helpers"><%= t("admin.helpers") %></option>
                <option value="admins"><%= t("admin.admins") %></option>
                <option value="publication"><%= t("admin.publicationRole") %></option>
              </select>
            </label>

            <label class="field">
              <span><%= t("admin.category") %></span>
              <select name="category" class="field-select">
                <option value="site_updates"><%= t("notifications.categorySiteUpdates") %></option>
                <option value="polls"><%= t("notifications.categoryPolls") %></option>
              </select>
            </label>

            <label class="field">
              <span><%= t("admin.message") %></span>
              <textarea name="message" rows="5" maxlength="500"></textarea>
            </label>
          </div>

          <div data-publication-news-fields hidden>
            <label class="field">
              <span><%= t("news.summary") %></span>
              <textarea name="summary" rows="3" maxlength="220"></textarea>
            </label>

            <label class="field">
              <span><%= t("news.content") %></span>
              <textarea name="content" rows="8" maxlength="5000"></textarea>
            </label>
          </div>

          <div data-publication-poll-fields hidden>
            <label class="field">
              <span><%= t("polls.question") %></span>
              <textarea name="question" rows="4" maxlength="300"></textarea>
            </label>

            <label class="field">
              <span><%= t("polls.options") %></span>
              <textarea name="options" rows="6" maxlength="1000" placeholder="Option 1&#10;Option 2&#10;Option 3"></textarea>
            </label>

            <label class="consent-check">
              <input type="checkbox" name="allowMultiple" />
              <span><%= t("polls.allowMultiple") %></span>
            </label>
          </div>

          <label class="field">
            <span><%= t("publication.publishAt") %></span>
            <input type="datetime-local" name="publishedAt" />
          </label>

          <button type="submit" class="primary-button"><%= t("publication.publishButton") %></button>
        </form>
      </section>

      <aside class="dashboard-card">
        <div class="section-head">
          <h2><%= t("publication.manage") %></h2>
        </div>

        <div class="section-head compact">
          <h2><%= t("publication.typeNotification") %></h2>
        </div>
        <% if (notifications.length === 0) { %>
          <p class="empty-state"><%= t("admin.noNotifications") %></p>
        <% } else { %>
          <div class="notifications-list compact">
            <% notifications.forEach((notification) => { %>
              <article class="notification-item">
                <div class="notification-meta">
                  <span><%= resolveNotificationCategoryLabel(notification.category) %></span>
                  <span><%= resolveNotificationTargetLabel(notification.target_role) %></span>
                  <span><%= notification.published_at.slice(0, 16).replace("T", " ") %></span>
                </div>
                <h3><%= notification.title %></h3>
                <p><%= notification.message %></p>
                <div class="table-actions">
                  <a href="/publications/notification/<%= notification.id %>/edit" class="ghost-button button-link"><%= t("publication.edit") %></a>
                  <form action="/publications/notification/<%= notification.id %>/delete" method="post">
                    <button type="submit" class="history-delete-button"><%= t("publication.delete") %></button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>

        <div class="section-head compact">
          <h2><%= t("publication.typeNews") %></h2>
        </div>
        <% if (newsPosts.length === 0) { %>
          <p class="empty-state"><%= t("news.none") %></p>
        <% } else { %>
          <div class="notifications-list compact">
            <% newsPosts.forEach((post) => { %>
              <article class="notification-item">
                <div class="notification-meta">
                  <span><%= post.published_at.slice(0, 16).replace("T", " ") %></span>
                </div>
                <h3><%= post.title %></h3>
                <p class="news-summary"><%= post.summary %></p>
                <div class="table-actions">
                  <a href="/publications/news/<%= post.id %>/edit" class="ghost-button button-link"><%= t("publication.edit") %></a>
                  <form action="/publications/news/<%= post.id %>/delete" method="post">
                    <button type="submit" class="history-delete-button"><%= t("publication.delete") %></button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>

        <div class="section-head compact">
          <h2><%= t("publication.typePoll") %></h2>
        </div>
        <% if (polls.length === 0) { %>
          <p class="empty-state"><%= t("polls.none") %></p>
        <% } else { %>
          <div class="notifications-list compact">
            <% polls.forEach((poll) => { %>
              <article class="notification-item">
                <div class="notification-meta">
                  <span><%= poll.allow_multiple ? t("polls.multipleChoice") : t("polls.singleChoice") %></span>
                  <span><%= poll.published_at.slice(0, 16).replace("T", " ") %></span>
                </div>
                <h3><%= poll.title %></h3>
                <p><%= poll.question %></p>
                <div class="table-actions">
                  <a href="/publications/poll/<%= poll.id %>/edit" class="ghost-button button-link"><%= t("publication.edit") %></a>
                  <form action="/publications/poll/<%= poll.id %>/delete" method="post">
                    <button type="submit" class="history-delete-button"><%= t("publication.delete") %></button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </aside>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
