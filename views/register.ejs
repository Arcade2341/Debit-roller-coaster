<%- include("partials/head", { pageTitle, metaRobots: "noindex,nofollow" }) %>
<%- include("partials/header") %>

<main class="auth-page">
  <section class="container form-page">
    <div class="form-shell">
      <div class="section-head">
        <span class="eyebrow"><%= t("auth.registerEyebrow") %></span>
        <h1><%= t("auth.registerTitle") %></h1>
      </div>

      <%- include("partials/flash") %>

      <form action="/register" method="post" class="stack-form">
        <label class="field">
          <span><%= t("auth.username") %></span>
          <input type="text" name="username" minlength="3" maxlength="30" required />
        </label>

        <label class="field">
          <span><%= t("auth.password") %></span>
          <input type="password" name="password" minlength="8" required />
        </label>

        <label class="field">
          <span><%= t("auth.confirmPassword") %></span>
          <input type="password" name="confirmPassword" minlength="8" required />
        </label>

        <label class="consent-check">
          <input type="checkbox" name="acceptCgu" required />
          <span><%- t("auth.acceptCgu") %></span>
        </label>

        <label class="consent-check">
          <input type="checkbox" name="acceptLegal" required />
          <span><%- t("auth.acceptLegal") %></span>
        </label>

        <label class="consent-check">
          <input type="checkbox" name="acceptPrivacy" required />
          <span><%- t("auth.acceptPrivacy") %></span>
        </label>

        <button type="submit" class="primary-button"><%= t("auth.createAccount") %></button>
      </form>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
