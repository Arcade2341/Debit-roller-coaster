<%- include("partials/head", { pageTitle, metaRobots: "noindex,nofollow" }) %>
<%- include("partials/header") %>

<main class="dashboard-page">
  <section class="container">
    <div class="page-intro">
      <div class="section-head">
        <h1><%= t("requests.title") %></h1>
        <p><%= t("requests.intro") %></p>
      </div>
    </div>

    <div class="dashboard-grid">
      <section class="dashboard-card">
        <div class="section-head">
          <h2><%= t("requests.list") %></h2>
        </div>

        <%- include("partials/flash") %>

        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th><%= t("requests.ride") %></th>
                <th><%= t("requests.park") %></th>
                <th><%= t("requests.country") %></th>
                <th><%= t("requests.peopleTrain") %></th>
                <th><%= t("requests.requester") %></th>
                <th><%= t("requests.status") %></th>
                <th><%= t("requests.action") %></th>
              </tr>
            </thead>
            <tbody>
              <% if (attractionRequests.length === 0) { %>
                <tr>
                  <td colspan="7"><%= t("requests.none") %></td>
                </tr>
              <% } else { %>
                <% attractionRequests.forEach((requestEntry) => { %>
                  <tr>
                    <td><%= requestEntry.attraction_name %></td>
                    <td><%= requestEntry.park_name %></td>
                    <td><%= requestEntry.country_name %></td>
                    <td><%= requestEntry.people_per_train %></td>
                    <td><%= requestEntry.requested_by_username || t("admin.user") %></td>
                    <td><%= requestEntry.status %></td>
                    <td>
                      <% if (requestEntry.status === "pending") { %>
                        <div class="table-actions">
                          <form action="/requests/<%= requestEntry.id %>/accept" method="post">
                            <button type="submit" class="history-delete-button"><%= t("requests.accept") %></button>
                          </form>
                          <form action="/requests/<%= requestEntry.id %>/reject" method="post">
                            <button type="submit" class="history-delete-button"><%= t("requests.reject") %></button>
                          </form>
                        </div>
                      <% } else { %>
                        <span><%= t("requests.processed") %></span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>

      <aside class="dashboard-card">
        <div class="section-head">
          <h2><%= t("requests.reminder") %></h2>
        </div>

        <p class="empty-state"><%= t("requests.reminderText") %></p>
      </aside>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
