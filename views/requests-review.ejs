<%- include("partials/head", { pageTitle, metaRobots: "noindex,nofollow" }) %>
<%- include("partials/header") %>

<main class="dashboard-page">
  <section class="container">
    <div class="page-intro">
      <div class="section-head">
        <h1>Demandes</h1>
        <p>Validez ou refusez les ajouts d'attractions.</p>
      </div>
    </div>

    <div class="dashboard-grid">
      <section class="dashboard-card">
        <div class="section-head">
          <h2>Demandes d'ajout</h2>
        </div>

        <%- include("partials/flash") %>

        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Attraction</th>
                <th>Parc</th>
                <th>Pays</th>
                <th>Pers./train</th>
                <th>Demandeur</th>
                <th>Statut</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (attractionRequests.length === 0) { %>
                <tr>
                  <td colspan="7">Aucune demande pour le moment.</td>
                </tr>
              <% } else { %>
                <% attractionRequests.forEach((requestEntry) => { %>
                  <tr>
                    <td><%= requestEntry.attraction_name %></td>
                    <td><%= requestEntry.park_name %></td>
                    <td><%= requestEntry.country_name %></td>
                    <td><%= requestEntry.people_per_train %></td>
                    <td><%= requestEntry.requested_by_username || "Utilisateur" %></td>
                    <td><%= requestEntry.status %></td>
                    <td>
                      <% if (requestEntry.status === "pending") { %>
                        <div class="table-actions">
                          <form action="/requests/<%= requestEntry.id %>/accept" method="post">
                            <button type="submit" class="history-delete-button">Accepter</button>
                          </form>
                          <form action="/requests/<%= requestEntry.id %>/reject" method="post">
                            <button type="submit" class="history-delete-button">Refuser</button>
                          </form>
                        </div>
                      <% } else { %>
                        <span>Traitee</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>

      <aside class="dashboard-card">
        <div class="section-head">
          <h2>Rappel</h2>
        </div>

        <p class="empty-state">Cette page sert seulement a accepter ou refuser les demandes.</p>
      </aside>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
